# Frontend
FRONT_URL="http://localhost:5173"

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=name
POSTGRES_USER=user
POSTGRES_PASSWORD=password
PGTZ="Europe/Moscow"

REDIS_HOST=localhost
REDIS_PORT=6379

# First user in seed
DEFAULT_USER_PASSWORD=password

# Secrets (JWT_SECRET нужен и API BFF для локальной проверки access JWT, и auth-сервису)
JWT_SECRET="myawesomesecret"
JWT_VERSION=0
CSRF_SECRET="myawesomesecret"

# Auth microservice gRPC (BFF подключается к этому адресу; в docker-compose задаётся auth:50051)
AUTH_GRPC_ADDR=localhost:50051
AUTH_GRPC_LISTEN=:50051

# AI microservice gRPC (BFF подключается к этому адресу; в docker-compose задаётся ai:50052)
AI_GRPC_ADDR=localhost:50052
AI_GRPC_LISTEN=:50052

# Fileserver (обязательно при FILESERVER_INTERNAL_URL у BFF; один и тот же токен у BFF и fileserver)
FILESERVER_LISTEN=:8082
FILESERVER_STORAGE_PATH=./static
FILESERVER_READ_TIMEOUT_SEC=30
FILESERVER_WRITE_TIMEOUT_SEC=120
FILESERVER_UPLOAD_TOKEN=02ba667481c3a860c286ddd04e57e06d6aa3e693f0206a02d4c1c21fc2bf988b
FILESERVER_INTERNAL_URL=
FILESERVER_PUBLIC_BASE=

# Backend
SERVER_URL="http://localhost:8080"
PORT=8080
DEBUG=true
# Валидный IP (см. internal/secure/rate_limiter). Локально: 127.0.0.1; в проде — IP вашего сервера за балансировщиком.
SERVER_IP="127.0.0.1"

# Voice to text
GROQ_API_KEY=awesowekey
PROXY_URL="socks5://127.0.0.1:10808" # Proxy settings for Groq

# Advertisement URL for iframe banners
ADVERTISEMENT_URL=https://motherfuckingwebsite.com
